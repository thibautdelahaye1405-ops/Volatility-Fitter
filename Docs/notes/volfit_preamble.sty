% volfit_preamble.sty — shared preamble for the Vol-Fitter Technical Notes series.
% Every note in Docs/notes/ does \usepackage{volfit_preamble} after \documentclass.
% Conventions, notation and macros are common across the series so that a reader
% who has met one note can read any other without relearning symbols.
\ProvidesPackage{volfit_preamble}[2026/06/28 Vol-Fitter technical-note series]

% ---------------------------------------------------------------- core math
\RequirePackage{amsmath,amssymb,amsthm,mathtools}
\RequirePackage{bm}
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}
\RequirePackage{microtype}
\RequirePackage{setspace}
\setstretch{1.05}
\allowdisplaybreaks

% ---------------------------------------------------------------- floats / tables / figures
\RequirePackage{booktabs,longtable,array,multirow}
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{caption}
\RequirePackage{enumitem}
\RequirePackage{xcolor}

% ---------------------------------------------------------------- code listings
\RequirePackage{listings}
\definecolor{codebg}{rgb}{0.97,0.97,0.97}
\definecolor{codekw}{rgb}{0.20,0.20,0.70}
\definecolor{codecm}{rgb}{0.40,0.50,0.40}
\lstdefinestyle{volfit}{
  language=Python,
  basicstyle=\ttfamily\small,
  keywordstyle=\color{codekw},
  commentstyle=\color{codecm}\itshape,
  backgroundcolor=\color{codebg},
  frame=single,
  rulecolor=\color{black!15},
  breaklines=true,
  showstringspaces=false,
  numbers=left,
  numberstyle=\tiny\color{black!45},
  xleftmargin=2.2em,
}
\lstset{style=volfit}

% ---------------------------------------------------------------- coloured asides
\RequirePackage[most]{tcolorbox}
% Heuristic / intuition box.
\newtcolorbox{heuristic}[1][]{colback=blue!4,colframe=blue!45!black,
  fonttitle=\bfseries,title={Heuristic},#1}
% Performance / numerical-optimisation box.
\newtcolorbox{perfbox}[1][]{colback=green!4,colframe=green!40!black,
  fonttitle=\bfseries,title={Performance},#1}
% Caution / pitfall box.
\newtcolorbox{caution}[1][]{colback=red!4,colframe=red!45!black,
  fonttitle=\bfseries,title={Caution},#1}
% Worked-example box (kept open across pages).
\newtcolorbox{example}[1][]{breakable,colback=black!2,colframe=black!55,
  fonttitle=\bfseries,title={Example},#1}

% ---------------------------------------------------------------- hyperlinks (load late)
\RequirePackage{hyperref}
\hypersetup{colorlinks=true,linkcolor=blue!55!black,citecolor=blue!50!black,
  urlcolor=blue!50!black}
\RequirePackage{cleveref}

% ---------------------------------------------------------------- theorem environments
\theoremstyle{definition}
\newtheorem{definition}{Definition}
\newtheorem{assumption}{Assumption}
\newtheorem{remark}{Remark}
\newtheorem{example*}{Example}
\theoremstyle{plain}
\newtheorem{proposition}{Proposition}
\newtheorem{lemma}{Lemma}
\newtheorem{theorem}{Theorem}
\newtheorem{corollary}{Corollary}

% ---------------------------------------------------------------- notation macros
% Number systems and measures.
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\E}{\mathbb{E}}
\newcommand{\Prob}{\mathbb{P}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\Var}{\operatorname{Var}}
\newcommand{\Cov}{\operatorname{Cov}}
% Differentials and small symbols.
\newcommand{\dd}{\mathrm{d}}
\newcommand{\1}{\mathbf{1}}
\newcommand{\eps}{\varepsilon}
\newcommand{\half}{\tfrac12}
% Normal density / cdf, used everywhere for the Black formula.
\newcommand{\PhiN}{\Phi}
\newcommand{\phin}{\varphi}
% Linear algebra.
\newcommand{\T}{^{\mathsf{T}}}
\newcommand{\pinv}{^{\dagger}}
\newcommand{\given}{\,|\,}
\DeclareMathOperator{\diag}{diag}
\DeclareMathOperator{\tr}{tr}
\DeclareMathOperator{\sgn}{sgn}
\DeclareMathOperator*{\argmin}{arg\,min}
\DeclareMathOperator*{\argmax}{arg\,max}
\DeclareMathOperator{\logit}{logit}
\DeclareMathOperator{\expit}{expit}
\DeclareMathOperator{\relu}{relu}
% Paired delimiters.
\DeclarePairedDelimiter{\abs}{\lvert}{\rvert}
\DeclarePairedDelimiter{\norm}{\lVert}{\rVert}
\DeclarePairedDelimiter{\inner}{\langle}{\rangle}
% Domain-specific shorthands shared across the series.
\newcommand{\BS}{\mathrm{BS}}                 % Black-Scholes subscript
\newcommand{\atm}{\mathrm{atm}}               % at-the-money subscript
\newcommand{\fwd}{F}                          % forward price
\newcommand{\logm}{k}                         % log-moneyness log(K/F)
\newcommand{\tvar}{w}                         % total implied variance sigma^2 T
\newcommand{\locvar}{\nu}                     % local variance
\newcommand{\Black}{B}                        % normalized Black call

% A consistent footer tag for every note in the series.
\newcommand{\seriesfooter}{Vol-Fitter Technical Notes}
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\thepage}
\fancyfoot[L]{\footnotesize\seriesfooter}
\renewcommand{\headrulewidth}{0pt}

\endinput
