# Per-desk configuration (BYO entitlement: the client's OWN feed credentials
# — the container ships computation, never market data). Copy to client.env;
# client.env is gitignored.

# Watchlist seeded on launch (editable in-app; saved universes persist on the
# /data volume).
VOLFIT_TICKERS=SPY,QQQ,AAPL

# Force the active source on launch ("yahoo" | "massive" | "synthetic");
# unset = best-reachable auto-pick. Bloomberg is desktop-only (needs a
# Terminal on the same machine).
#VOLFIT_PROVIDER=massive

# Massive/Polygon REST key (lights up the Massive source).
#VOLFIT_MASSIVE_KEY=

# Delayed-tier WebSocket book (optional): wss://delayed.polygon.io/options
#VOLFIT_MASSIVE_WS_URL=

# Flat-file S3 history (optional; lights up past-day captured replay).
#VOLFIT_FLATFILES_KEY=
#VOLFIT_FLATFILES_SECRET=
#VOLFIT_FLATFILES_ENDPOINT=files.massive.com
